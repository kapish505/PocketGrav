# ─── Google OAuth ─────────────────────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Run: openssl rand -base64 32
NEXTAUTH_SECRET=
# Local development URL:
NEXTAUTH_URL=http://localhost:3000
# When deployed to Vercel, update this:
# NEXTAUTH_URL=https://your-app.vercel.app

# ─── Supabase ─────────────────────────────────────────────────────────────────
# supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Ingest API Key ────────────────────────────────────────────────────────────
# A random shared secret between reporter.js and the /api/ingest endpoint.
# Generate: openssl rand -base64 24
INGEST_API_KEY=

# When deployed to Vercel, set this on your laptop too:
# INGEST_URL=https://your-app.vercel.app/api/ingest

# ─── Reporter (laptop-side) ────────────────────────────────────────────────────
# Your Gmail address (same one you log in with)
REPORTER_USER_EMAIL=your.email@gmail.com
# Path to your AntiGravity brain directory
ANTIGRAVITY_BRAIN_PATH=/Users/kapish/.gemini/antigravity/brain
